# Expo client talking to the production backend
EXPO_PUBLIC_CONVEX_URL=https://your-production-deployment.convex.cloud
EXPO_PUBLIC_CONVEX_SITE_URL=https://your-production-deployment.convex.site

# Better Auth / Google server secrets for the production deployment
BETTER_AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SITE_URL=https://your-web-app.example.com

# Optional extra trusted web origins for Better Auth, comma-separated.
# Set this when you add a production web app origin.
BETTER_AUTH_TRUSTED_ORIGINS=

# Reed AI provider keys for the production deployment.
# XAI_API_KEY powers live Reed chat. OPENAI_API_KEY powers private coach-state refreshes.
# GOOGLE_API_KEY or GEMINI_API_KEY powers lightweight memory compaction, context planning, and image observations.
XAI_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=

# Optional Langfuse tracing for Convex AI workflows.
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=

# PostHog analytics (Expo client)
POSTHOG_PROJECT_TOKEN=
POSTHOG_HOST=

# Optional Reed AI model overrides.
REED_CHAT_MODEL=grok-4.3
REED_COACH_STATE_MODEL=gpt-5.2
REED_COACH_STATE_REASONING_EFFORT=low
REED_SUMMARY_MODEL=gpt-5.4-mini-2026-03-17
REED_CONTEXT_PLANNER_MODEL=gpt-5.4-mini-2026-03-17
REED_COACHING_MEMORY_MODEL=gpt-5.4-mini-2026-03-17
REED_IMAGE_ANALYSIS_MODEL=gpt-5.4-mini-2026-03-17
REED_PROFILE_INSIGHT_MODEL=gpt-5.4-mini-2026-03-17
REED_STT_MODEL=gpt-4o-mini-transcribe
REED_NOTE_POLISH_MODEL=gpt-5.4-mini-2026-03-17

# Secret required by convex/reed.ts:upsertActivePrompt for runtime prompt edits.
REED_CONTROL_PANEL_SECRET=
