# Expo client talking to the production backend
EXPO_PUBLIC_CONVEX_URL=https://your-production-deployment.convex.cloud
EXPO_PUBLIC_CONVEX_SITE_URL=https://your-production-deployment.convex.site

# Better Auth / Google server secrets for the production deployment
BETTER_AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SITE_URL=https://your-web-app.example.com

# Optional extra trusted web origins for Better Auth, comma-separated.
# Set this when you add a production web app origin.
BETTER_AUTH_TRUSTED_ORIGINS=
