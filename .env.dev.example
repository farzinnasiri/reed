# Convex dev deployment selected by `convex dev`
CONVEX_DEPLOYMENT=dev:your-dev-deployment

# Expo client talking to the dev backend
EXPO_PUBLIC_CONVEX_URL=https://your-dev-deployment.convex.cloud
EXPO_PUBLIC_CONVEX_SITE_URL=https://your-dev-deployment.convex.site

# Better Auth / Google server secrets for the dev deployment
BETTER_AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SITE_URL=http://localhost:8081

# Optional extra trusted web origins for Better Auth, comma-separated.
# Local Expo web on localhost:8081 is already allowed by default.
BETTER_AUTH_TRUSTED_ORIGINS=

# Reed AI provider keys for the dev deployment.
# XAI_API_KEY powers live Reed chat. GOOGLE_API_KEY or GEMINI_API_KEY powers lightweight memory compaction, context planning, and image observations.
XAI_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=

# Optional Reed AI model overrides.
REED_CHAT_MODEL=grok-4.3
REED_SUMMARY_MODEL=gemini-2.5-flash-lite
REED_CONTEXT_PLANNER_MODEL=gemini-2.5-flash-lite
REED_IMAGE_ANALYSIS_MODEL=gemini-3.1-flash-lite
REED_PROFILE_INSIGHT_MODEL=gemini-2.5-flash-lite

# Optional secret required by convex/reed.ts:upsertActivePrompt for runtime prompt edits.
REED_PROMPT_ADMIN_SECRET=
