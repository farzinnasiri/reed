# Convex dev deployment selected by `convex dev`
CONVEX_DEPLOYMENT=dev:your-dev-deployment

# Expo client talking to the dev backend
EXPO_PUBLIC_CONVEX_URL=https://your-dev-deployment.convex.cloud
EXPO_PUBLIC_CONVEX_SITE_URL=https://your-dev-deployment.convex.site

# Better Auth / Google server secrets for the dev deployment
BETTER_AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SITE_URL=http://localhost:8081

# Optional extra trusted web origins for Better Auth, comma-separated.
# Local Expo web on localhost:8081 is already allowed by default.
BETTER_AUTH_TRUSTED_ORIGINS=
