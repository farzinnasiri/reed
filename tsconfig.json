{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "skipLibCheck": true,
    "strict": true,
    "paths": {
      "react-native-gifted-chat": [
        "./types/react-native-gifted-chat"
      ],
      "@/*": [
        "./*"
      ]
    }
  },
  "exclude": [
    "legacy",
    "convex"
  ],
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
